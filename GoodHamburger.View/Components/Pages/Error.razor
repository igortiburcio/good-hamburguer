@page "/Error"
@using System.Diagnostics

<PageTitle>Erro</PageTitle>

<div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-2 text-3xl font-bold text-slate-900">Ocorreu um erro</h1>
    <p class="mb-6 text-slate-600">A operacao nao pode ser concluida nesta tela.</p>

    @if (ShowRequestId)
    {
        <p class="mb-6 rounded-md bg-slate-100 px-3 py-2 text-sm text-slate-700">
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <a href="/" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Voltar ao inicio</a>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
