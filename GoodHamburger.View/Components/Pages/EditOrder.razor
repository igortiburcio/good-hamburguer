@page "/orders/{Id}/edit"
@inherits GoodHamburger.View.Components.Pages.OrderFormBase

<PageTitle>Editar Pedido</PageTitle>

<div class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900">Editar pedido</h1>
    <p class="mb-6 text-slate-600">Atualize cliente e itens.</p>

    <GoodHamburger.View.Components.Shared.ApiErrorAlert Code="@ErrorCode" Message="@ErrorMessage" />

@if (IsLoading)
    {
        <div class="rounded-lg border border-slate-200 bg-white p-6 text-slate-600">Carregando dados do pedido...</div>
}
    else
    {
        <div class="space-y-6">
            <div class="rounded-xl border border-slate-200 bg-white p-6">
                <label class="mb-2 block text-sm font-semibold text-slate-700">Nome do cliente</label>
                <input class="w-full rounded-md border border-slate-300 px-3 py-2" @bind="ClientName" />
            </div>

            @foreach (var group in GroupedMenu())
            {
                <div class="rounded-xl border border-slate-200 bg-white p-6">
                    <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-slate-700">@group.Key</label>
                    <select class="w-full rounded-md border border-slate-300 px-3 py-2" @bind="SelectedByCategory[group.Key]">
                        <option value="">Nenhum</option>
                        @foreach (var item in group)
                        {
                            <option value="@item.Id">@item.Name (@item.Price.ToString("C"))</option>
                        }
                    </select>
                </div>
            }

            <div class="flex gap-3">
                <button class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:opacity-60" disabled="@IsSubmitting" type="button" @onclick="UpdateAsync">
                    @if (IsSubmitting)
                    {
                        <span>Salvando...</span>
                    }
                    else
                    {
                        <span>Salvar alteracoes</span>
                    }
                </button>
                <a href="/orders" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Cancelar</a>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadMenuAsync();

        var result = await OrdersApiClient.GetByIdAsync(Id);
        if (!result.IsSuccess || result.Data is null)
        {
            ErrorCode = result.ErrorCode;
            ErrorMessage = result.ErrorMessage;
            return;
        }

        ClientName = result.Data.ClientName;

        foreach (var product in result.Data.Products)
        {
            var found = MenuItems.FirstOrDefault(mi => mi.Id == product.Id);
            if (found is not null)
            {
                SelectedByCategory[found.Category] = found.Id;
            }
        }
    }

    private async Task UpdateAsync()
    {
        await SubmitAsync(request => OrdersApiClient.UpdateAsync(Id, request));
    }
}
