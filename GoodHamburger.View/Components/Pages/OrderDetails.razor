@page "/orders/{Id}"
@inject GoodHamburger.View.Services.IOrdersApiClient OrdersApiClient

<PageTitle>Detalhes do Pedido</PageTitle>

<div class="mx-auto max-w-4xl px-4 py-8">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">Detalhes do pedido</h1>
            <p class="text-slate-600">Visualizacao completa do pedido.</p>
        </div>
        <div class="flex gap-2">
            <a href="@($"/orders/{Id}/edit")" class="rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Editar</a>
            <a href="/orders" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800">Voltar</a>
        </div>
    </div>

    <GoodHamburger.View.Components.Shared.ApiErrorAlert Code="@_errorCode" Message="@_errorMessage" />

    @if (_isLoading)
    {
        <div class="rounded-lg border border-slate-200 bg-white p-6 text-slate-600">Carregando pedido...</div>
    }
    else if (_order is not null)
    {
        <div class="space-y-5">
            <div class="rounded-xl border border-slate-200 bg-white p-6">
                <div class="text-sm text-slate-500">Cliente</div>
                <div class="text-xl font-semibold text-slate-900">@_order.ClientName</div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-6">
                <div class="mb-3 text-sm font-semibold text-slate-700">Itens</div>
                <ul class="space-y-2">
                    @foreach (var product in _order.Products)
                    {
                        <li class="flex items-center justify-between rounded-md border border-slate-100 px-3 py-2">
                            <div>
                                <div class="font-medium text-slate-900">@product.Name</div>
                                <div class="text-xs uppercase tracking-wide text-slate-500">@product.Category</div>
                            </div>
                            <div class="font-semibold text-slate-700">@product.Price.ToString("C")</div>
                        </li>
                    }
                </ul>
            </div>

            <div class="grid gap-4 sm:grid-cols-3">
                <div class="rounded-xl border border-slate-200 bg-white p-5">
                    <div class="text-xs uppercase tracking-wide text-slate-500">Subtotal</div>
                    <div class="text-xl font-bold text-slate-900">@_order.Subtotal.ToString("C")</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-5">
                    <div class="text-xs uppercase tracking-wide text-slate-500">Desconto</div>
                    <div class="text-xl font-bold text-emerald-700">@_order.Discount.ToString("C")</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-5">
                    <div class="text-xs uppercase tracking-wide text-slate-500">Total</div>
                    <div class="text-xl font-bold text-slate-900">@_order.TotalFinal.ToString("C")</div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private bool _isLoading = true;
    private GoodHamburger.View.Services.OrderResponseDto? _order;
    private string? _errorCode;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var result = await OrdersApiClient.GetByIdAsync(Id);
        if (!result.IsSuccess)
        {
            _errorCode = result.ErrorCode;
            _errorMessage = result.ErrorMessage;
        }
        else
        {
            _order = result.Data;
        }

        _isLoading = false;
    }
}
