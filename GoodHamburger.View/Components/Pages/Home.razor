@page "/"

<PageTitle>Inicio</PageTitle>

<div class="mx-auto max-w-5xl px-4 py-8">
    <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900">Good Hamburger</h1>
    <p class="mb-8 text-slate-600">Painel para operacao do cardapio e pedidos.</p>

    <div class="grid gap-4 sm:grid-cols-2">
        <a href="/menu" class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow">
            <div class="text-sm uppercase tracking-wide text-slate-500">Cardapio</div>
            <div class="mt-2 text-xl font-semibold text-slate-900">Consultar itens</div>
            <p class="mt-2 text-sm text-slate-600">Veja produtos por categoria e preco.</p>
        </a>

        <a href="/orders" class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow">
            <div class="text-sm uppercase tracking-wide text-slate-500">Pedidos</div>
            <div class="mt-2 text-xl font-semibold text-slate-900">Gerenciar pedidos</div>
            <p class="mt-2 text-sm text-slate-600">Criar, editar, consultar e excluir pedidos.</p>
        </a>
    </div>
</div>
